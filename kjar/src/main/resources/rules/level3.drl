package rules;

import com.ftn.sbnz.model.Flight;
import com.ftn.sbnz.model.facts.*;

// Hijerarhija odluka: CANCEL (100) -> DELAY (50) -> DEPART (10)

// --- ODLUKA: CANCEL (Salience 100) ---

rule "Decision - CANCEL due to extreme weather and runway problems"
salience 100
when
    $f : Flight($fn : flightNumber)
    TakeoffForbidden(flightNumber == $fn)
    RunwayProblem(flightNumber == $fn)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.CANCEL, "Critical: Extreme weather conditions combined with runway non-operational status or contamination.");
    rec.setFlightNumber($fn);
    insert(rec);
end

rule "Decision - CANCEL due to critical weather minimums"
salience 100
when
    $f : Flight($fn : flightNumber)
    TakeoffForbidden(flightNumber == $fn)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.CANCEL, "Critical: Takeoff prohibited due to violation of meteorological minimums.");
    rec.setFlightNumber($fn);
    insert(rec);
end


// --- ODLUKA: DELAY / REDIRECT (Salience 50) ---

rule "Decision - DELAY due to contaminated surfaces"
salience 50
when
    $f : Flight($fn : flightNumber)
    SurfacesContaminated(flightNumber == $fn)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.DELAY, "Operational Delay: Mandatory entry into aircraft de-icing treatment procedure.");
    rec.setFlightNumber($fn);
    insert(rec);
end

rule "Decision - DELAY due to runway problems"
salience 50
when
    $f : Flight($fn : flightNumber)
    RunwayProblem(flightNumber == $fn)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.DELAY, "Operational Delay: Runway requires cleaning or state assessment.");
    rec.setFlightNumber($fn);
    insert(rec);
end

rule "Decision - DELAY due to difficult runway conditions"
salience 50
when
    $f : Flight($fn : flightNumber)
    RunwayDifficult(flightNumber == $fn)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.DELAY, "Operational Delay: Traffic caution. Runway conditions are risky.");
    rec.setFlightNumber($fn);
    insert(rec);
end


// --- ODLUKA: DEPART_ON_TIME (Salience 10) ---

rule "Decision - DEPART_ON_TIME"
salience 10
when
    $f : Flight($fn : flightNumber)
    not Recommendation(flightNumber == $fn)
then
    Recommendation rec = new Recommendation(RecommendationAction.DEPART_ON_TIME, "All operational systems, technical parameters, and weather conditions are within normal limits.");
    rec.setFlightNumber($fn);
    insert(rec);
end