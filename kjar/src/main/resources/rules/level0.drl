package rules;

import com.ftn.sbnz.model.Flight;
import com.ftn.sbnz.model.Condition;
import com.ftn.sbnz.model.ConditionMet;
import com.ftn.sbnz.model.WeatherReport;
import com.ftn.sbnz.model.Runway;
import com.ftn.sbnz.model.Crew;
import com.ftn.sbnz.model.Aircraft;
import com.ftn.sbnz.model.facts.*;

// ==================== CONDITION TREE ====================

rule "Backward - Insert Condition Tree"
salience 1000
when
    $f : Flight($fn : flightNumber)
then
    // Root
    insert(new Condition("takeoffAllowed", "weatherPermits"));
    insert(new Condition("takeoffAllowed", "runwayReady"));
    insert(new Condition("takeoffAllowed", "aircraftReady"));
    insert(new Condition("takeoffAllowed", "crewCapable"));

    // Weather
    insert(new Condition("weatherPermits", "windAcceptable"));
    insert(new Condition("weatherPermits", "visibilityAcceptable"));
    insert(new Condition("weatherPermits", "noActiveIcing"));
    insert(new Condition("weatherPermits", "precipitationSafe"));

    // Runway
    insert(new Condition("runwayReady", "runwayNotClosed"));
    insert(new Condition("runwayReady", "runwayRwyccAcceptable"));

    // Aircraft
    insert(new Condition("aircraftReady", "noCriticalAlarms"));
    insert(new Condition("aircraftReady", "melCategoryOk"));
    insert(new Condition("aircraftReady", "serviceNotExceeded"));

    // Crew
    insert(new Condition("crewCapable", "crewComplete"));
    insert(new Condition("crewCapable", "fdpNotExceeded"));
    insert(new Condition("crewCapable", "restSufficient"));
end

// ==================== CONDITION MET — WEATHER ====================

rule "ConditionMet - windAcceptable - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not TailwindDetected(flightNumber == $fn)
    not CriticalCrosswindDetected(flightNumber == $fn)
then
    insert(new ConditionMet("windAcceptable", true));
end

rule "ConditionMet - windAcceptable - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $w : WeatherReport()
    (TailwindDetected(flightNumber == $fn) or CriticalCrosswindDetected(flightNumber == $fn))
then
    String msg = "tailwind: " + $w.getTailwind() + " km/h (must be < 19) | crosswind: " + $w.getCrosswind() + " km/h (must be < 65)";
    insert(new ConditionMet("windAcceptable", false, msg));
end

rule "ConditionMet - visibilityAcceptable - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not LowVisibility(flightNumber == $fn)
    not CriticalVisibility(flightNumber == $fn)
    not ZeroVisibility(flightNumber == $fn)
then
    insert(new ConditionMet("visibilityAcceptable", true));
end

rule "ConditionMet - visibilityAcceptable - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $w : WeatherReport()
    (LowVisibility(flightNumber == $fn) or CriticalVisibility(flightNumber == $fn) or ZeroVisibility(flightNumber == $fn))
then
    insert(new ConditionMet("visibilityAcceptable", false, "visibility is: " + $w.getVisibility() + "m, must be >= 550m"));
end

rule "ConditionMet - noActiveIcing - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not ActiveIcing(flightNumber == $fn)
    not FrostRisk(flightNumber == $fn)
then
    insert(new ConditionMet("noActiveIcing", true));
end

rule "ConditionMet - noActiveIcing - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $w : WeatherReport()
    (ActiveIcing(flightNumber == $fn) or FrostRisk(flightNumber == $fn))
then
    String msg = "icing risk detected (temperature: " + $w.getTemperature() + "C, dew point: " + $w.getDewPoint() + "C)";
    insert(new ConditionMet("noActiveIcing", false, msg));
end

rule "ConditionMet - precipitationSafe - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not FreezingRain(flightNumber == $fn)
    not Hail(flightNumber == $fn)
    not IcePellets(flightNumber == $fn)
    not HeavySnow(flightNumber == $fn)
then
    insert(new ConditionMet("precipitationSafe", true));
end

rule "ConditionMet - precipitationSafe - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $w : WeatherReport()
    (FreezingRain(flightNumber == $fn) or Hail(flightNumber == $fn) or IcePellets(flightNumber == $fn) or HeavySnow(flightNumber == $fn))
then
    insert(new ConditionMet("precipitationSafe", false, "hazardous precipitation: " + $w.getPrecipitationType() + " (" + $w.getPrecipitationIntensity() + ")"));
end

// ==================== CONDITION MET — RUNWAY ====================

rule "ConditionMet - runwayNotClosed - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not RunwayUnavailable(flightNumber == $fn)
then
    insert(new ConditionMet("runwayNotClosed", true));
end

rule "ConditionMet - runwayNotClosed - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $r : Runway()
    RunwayUnavailable(flightNumber == $fn)
then
    insert(new ConditionMet("runwayNotClosed", false, "runway is out of service. Status: " + $r.getStatus()));
end

rule "ConditionMet - runwayRwyccAcceptable - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not RunwayCritical(flightNumber == $fn)
    not RunwayRisky(flightNumber == $fn)
then
    insert(new ConditionMet("runwayRwyccAcceptable", true));
end

rule "ConditionMet - runwayRwyccAcceptable - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $r : Runway()
    (RunwayCritical(flightNumber == $fn) or RunwayRisky(flightNumber == $fn))
then
    insert(new ConditionMet("runwayRwyccAcceptable", false, "runway condition code (RWYCC) is critical: " + $r.getRwycc() + " (must be >= 4)"));
end

// ==================== CONDITION MET — AIRCRAFT ====================

rule "ConditionMet - noCriticalAlarms - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not TechnicalProblem(flightNumber == $fn)
    not CriticalAlarmDetected(flightNumber == $fn)
then
    insert(new ConditionMet("noCriticalAlarms", true));
end

rule "ConditionMet - noCriticalAlarms - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    (TechnicalProblem(flightNumber == $fn) or CriticalAlarmDetected(flightNumber == $fn))
then
    insert(new ConditionMet("noCriticalAlarms", false, "active critical or high severity technical alarms on the aircraft"));
end

rule "ConditionMet - melCategoryOk - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not MelCategoryA(flightNumber == $fn)
    not UnexpectedFailure(flightNumber == $fn)
then
    insert(new ConditionMet("melCategoryOk", true));
end

rule "ConditionMet - melCategoryOk - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    (MelCategoryA(flightNumber == $fn) or UnexpectedFailure(flightNumber == $fn))
then
    insert(new ConditionMet("melCategoryOk", false, "non-MEL or Category A failures prevent safe takeoff"));
end

rule "ConditionMet - serviceNotExceeded - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not ACheckExceeded(flightNumber == $fn)
    not CalendarServiceExceeded(flightNumber == $fn)
then
    insert(new ConditionMet("serviceNotExceeded", true));
end

rule "ConditionMet - serviceNotExceeded - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $ac : Aircraft()
    (ACheckExceeded(flightNumber == $fn) or CalendarServiceExceeded(flightNumber == $fn))
then
    String msg = "service interval exceeded: " + $ac.getFlightHoursSinceService() + "h since last service (limit 600h) or next date: " + $ac.getNextServiceDate();
    insert(new ConditionMet("serviceNotExceeded", false, msg));
end

// ==================== CONDITION MET — CREW ====================

rule "ConditionMet - crewComplete - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not CrewIncomplete(flightNumber == $fn)
then
    insert(new ConditionMet("crewComplete", true));
end

rule "ConditionMet - crewComplete - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    CrewIncomplete(flightNumber == $fn)
then
    insert(new ConditionMet("crewComplete", false, "crew composition is incomplete for this flight operation"));
end

rule "ConditionMet - fdpNotExceeded - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not CrewExceededLimit(flightNumber == $fn)
    not CrewOverloaded(flightNumber == $fn)
then
    insert(new ConditionMet("fdpNotExceeded", true));
end

rule "ConditionMet - fdpNotExceeded - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $c : Crew(flightNumber == $fn)
    (CrewExceededLimit(flightNumber == $fn) or CrewOverloaded(flightNumber == $fn))
then
    String msg = "crew flight duty period limit exceeded. Current FDP: " + $c.getFdp() + "h, sectors today: " + $c.getSectorsToday();
    insert(new ConditionMet("fdpNotExceeded", false, msg));
end

rule "ConditionMet - restSufficient - true"
salience 200
when
    $f : Flight($fn : flightNumber)
    not InsufficientRest(flightNumber == $fn)
then
    insert(new ConditionMet("restSufficient", true));
end

rule "ConditionMet - restSufficient - false"
salience 200
when
    $f : Flight($fn : flightNumber)
    $c : Crew(flightNumber == $fn)
    InsufficientRest(flightNumber == $fn)
then
    insert(new ConditionMet("restSufficient", false, "insufficient crew rest period before flight: " + $c.getRestBeforeFlight() + "h (minimum 12h)"));
end