package rules;

import com.ftn.sbnz.model.Flight;
import com.ftn.sbnz.model.WeatherReport;
import com.ftn.sbnz.model.Runway;
import com.ftn.sbnz.model.facts.*;

rule "Meteo - Tailwind Component"
salience 500
when
    $f : Flight($fn : flightNumber)
    WeatherReport(tailwind > 19)
then
    TailwindDetected fact = new TailwindDetected();
    fact.setFlightNumber($fn);
    insert(fact); 
end

rule "Meteo - Zero Visibility"
salience 500
when
    $f : Flight($fn : flightNumber)
    WeatherReport(visibility < 75) /
then
    ZeroVisibility fact = new ZeroVisibility();
    fact.setFlightNumber($fn);
    insert(fact);
    
    TakeoffForbidden tf = new TakeoffForbidden();
    tf.setFlightNumber($fn);
    insert(tf);
end

rule "Meteo - Frost Risk"
salience 500
when
    $f : Flight($fn : flightNumber)
    WeatherReport(temperature <= 0, dewPoint >= temperature) 
then
    FrostRisk fact = new FrostRisk();
    fact.setFlightNumber($fn);
    insert(fact);
    
    SurfacesContaminated sc = new SurfacesContaminated();
    sc.setFlightNumber($fn);
    insert(sc);
end

rule "Infrastructure - Runway Critical State"
salience 500
when
    $f : Flight($fn : flightNumber)
    Runway(rwycc <= 1)
then
    RunwayCritical fact = new RunwayCritical();
    fact.setFlightNumber($fn);
    insert(fact);
    
    RunwayProblem rp = new RunwayProblem();
    rp.setFlightNumber($fn);
    insert(rp);
end

rule "Infrastructure - Runway Risky"
salience 500
when
    $f : Flight($fn : flightNumber)
    Runway(deicingComplete == false || (rwycc > 1 && rwycc <= 3)) 
then
    RunwayRisky fact = new RunwayRisky();
    fact.setFlightNumber($fn);
    insert(fact);
    
    RunwayDifficult rd = new RunwayDifficult();
    rd.setFlightNumber($fn);
    insert(rd);
end