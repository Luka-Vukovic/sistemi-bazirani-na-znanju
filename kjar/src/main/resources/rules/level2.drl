package rules;

import com.ftn.sbnz.model.Flight;
import com.ftn.sbnz.model.facts.*;


rule "Aggregation - Runway Problem due to difficult runway and snow or ice"
salience 500
when
    $f : Flight($fn : flightNumber)
    RunwayDifficult(flightNumber == $fn)
    SurfacesContaminated(flightNumber == $fn)
then
    System.out.println(String.format(
        ">>> [LEVEL 2 - AGGREGATION] Flight #%s: Critical combination detected! Difficult runway conditions combined with surface contamination (frost/ice/snow). Forwarding to Level 3 for DELAY assessment.", 
        $fn
    ));
end

rule "Aggregation - Runway Problem due to difficult runway and strong tailwind"
salience 500
when
    $f : Flight($fn : flightNumber)
    RunwayDifficult(flightNumber == $fn)
    TailwindDetected(flightNumber == $fn)
then
    System.out.println(String.format(
        ">>> [LEVEL 2 - AGGREGATION] Flight #%s: Operational risk warning! Combination of difficult runway conditions and strong tailwind component detected. Increased caution required.", 
        $fn
    ));
end

rule "Aggregation - Takeoff Forbidden due to combined CRITICAL hazards"
salience 500
when
    $f : Flight($fn : flightNumber)
    RunwayCritical(flightNumber == $fn) 
    SurfacesContaminated(flightNumber == $fn)
then
    TakeoffForbidden factDr = new TakeoffForbidden();
    factDr.setFlightNumber($fn);
    insert(factDr);
end

rule "Aggregation - Takeoff Forbidden due to critical runway state"
salience 500
when
    $f : Flight($fn : flightNumber)
    RunwayCritical(flightNumber == $fn)
then
    TakeoffForbidden factDr = new TakeoffForbidden();
    factDr.setFlightNumber($fn);
    insert(factDr);
end