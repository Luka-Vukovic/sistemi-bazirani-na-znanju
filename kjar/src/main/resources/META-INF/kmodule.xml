<?xml version="1.0" encoding="UTF-8"?>
<kmodule xmlns="http://www.drools.org/xsd/kmodule"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://www.drools.org/xsd/kmodule http://www.drools.org/xsd/kmodule/kmodule.xsd">

    <kbase name="rules" packages="rules" eventProcessingMode="stream">
        <ksession name="ksession-rules" type="stateful" clockType="realtime"/>
    </kbase>

    <kbase name="accumulate-rules" packages="rules.accumulate">
        <ksession name="ksession-accumulate" type="stateful"/>
    </kbase>

</kmodule>